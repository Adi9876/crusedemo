NODE_ENV=development
HOST=0.0.0.0
PORT=4000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crusex_auth?schema=public
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-characters
ACCESS_TOKEN_TTL=15m
REFRESH_SESSION_TTL_DAYS=30
REFRESH_TOKEN_BYTES=48
BCRYPT_SALT_ROUNDS=12

# Bybit Exchange API Integration
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_USE_TESTNET=true
PLATFORM_USER_ID=

# SMTP & Email Verification Config
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@crusex.com
EMAIL_VERIFICATION_REQUIRED=false
